# Local SQLite DB (default)
DATABASE_URL="file:./dev.db"

# Protect /admin routes with HTTP Basic Auth
# (Recommended for staging/prod; safe for local too.)
ADMIN_USER="admin"
ADMIN_PASS="change-me"

# Optional: send email notifications for new bookings
# (If not set, bookings are still saved in DB.)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@wcvs.example"
BOOKINGS_NOTIFY_TO=""

# Public branding / contact
NEXT_PUBLIC_CONTACT_EMAIL="hello@wcvs.example"
NEXT_PUBLIC_PHONE="(555) 555-5555"
